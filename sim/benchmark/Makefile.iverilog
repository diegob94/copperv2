.PHONY: all
all: run

work/sim.vvp: testbench.v fake_memory.v include/testbench_h.v
	mkdir -p work
	iverilog -s $(TOPLEVEL) $(VERILOG_SOURCES) -o $@ $(COMPILE_ARGS)

.PHONY: run
run: work/sim.vvp $(HEX_FILE)
	cd work; vvp sim.vvp $(PLUSARGS)

.PHONY: clean
clean:
	rm -rf work

include Makefile.common
